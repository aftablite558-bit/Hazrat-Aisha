rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Staff photos
    match /staff/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    // Gallery is public read, but restricted write
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'principal'];
    }
    // Documents are restricted based on roles
    match /documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'principal', 'teacher'];
    }
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
